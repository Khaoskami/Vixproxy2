# ─── VixKnight v2 Configuration ──────────────────────
# Copy this to .env and fill in real values

# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Comma-separated list of additional allowed CORS origins for the dashboard.
# BASE_URL is always allowed. /v1 proxy routes always allow any origin (RP frontends).
# Example: ALLOWED_ORIGINS=https://vixai.org,https://vixknight-production.up.railway.app
ALLOWED_ORIGINS=

# ─── Supabase ────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ─── new-api Upstream ────────────────────────────────
# The URL where your new-api instance is running.
# This is the relay that handles actual LLM provider routing.
# If running via docker-compose, this is usually http://new-api:3000
NEW_API_URL=http://localhost:3001
# Admin token from new-api (create one in its dashboard)
NEW_API_ADMIN_TOKEN=sk-your-new-api-admin-token

# ─── Auth ────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_EXPIRY=24h

# ─── Rate Limits ─────────────────────────────────────
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300
